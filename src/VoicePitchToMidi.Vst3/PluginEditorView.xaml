<UserControl x:Class="VoicePitchToMidi.Vst3.PluginEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0D0D0D" Width="420" Height="520">

    <UserControl.Resources>
        <!-- Colors -->
        <Color x:Key="BgDark">#0D0D0D</Color>
        <Color x:Key="BgCard">#1A1A1A</Color>
        <Color x:Key="BgHover">#252525</Color>
        <Color x:Key="Accent">#00D4AA</Color>
        <Color x:Key="AccentDim">#00A080</Color>
        <Color x:Key="TextPrimary">#FFFFFF</Color>
        <Color x:Key="TextSecondary">#808080</Color>
        <Color x:Key="NoteColor">#00FF88</Color>
        <Color x:Key="FreqColor">#00BFFF</Color>
        <Color x:Key="ConfColor">#FFB800</Color>

        <SolidColorBrush x:Key="BgDarkBrush" Color="{StaticResource BgDark}"/>
        <SolidColorBrush x:Key="BgCardBrush" Color="{StaticResource BgCard}"/>
        <SolidColorBrush x:Key="BgHoverBrush" Color="{StaticResource BgHover}"/>
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
        <SolidColorBrush x:Key="AccentDimBrush" Color="{StaticResource AccentDim}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>

        <!-- Default TextBlock Style -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
        </Style>

        <!-- Slider is created in code-behind with custom visuals -->

        <!-- ScrollViewer Style -->
        <Style TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"/>
                            <ScrollBar x:Name="PART_VerticalScrollBar" Grid.Column="1"
                                       Orientation="Vertical" Width="6"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="VOICE PITCH TO MIDI" FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource AccentBrush}" />
            <TextBlock Text="Real-time pitch detection" FontSize="11"
                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Main Pitch Display -->
        <Border Grid.Row="1" Background="{StaticResource BgCardBrush}" CornerRadius="12" Padding="24" Margin="0,0,0,16">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Note Display (Large, Center) -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                    <TextBlock Text="NOTE" FontSize="10" FontWeight="SemiBold"                                Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="NoteDisplay" Text="---" FontSize="56" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,4,0,0">
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="{StaticResource NoteColor}"/>
                        </TextBlock.Foreground>
                        <TextBlock.Effect>
                            <DropShadowEffect Color="{StaticResource NoteColor}" BlurRadius="20" ShadowDepth="0" Opacity="0.4"/>
                        </TextBlock.Effect>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Secondary Stats -->
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Frequency -->
            <Border Grid.Column="0" Background="{StaticResource BgCardBrush}" CornerRadius="10" Padding="16">
                <StackPanel>
                    <TextBlock Text="FREQUENCY" FontSize="9" FontWeight="SemiBold"                                Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock x:Name="FrequencyDisplay" Text="0.0 Hz" FontSize="22" FontWeight="SemiBold" Margin="0,6,0,0">
                        <TextBlock.Foreground>
                            <SolidColorBrush Color="{StaticResource FreqColor}"/>
                        </TextBlock.Foreground>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Confidence -->
            <Border Grid.Column="2" Background="{StaticResource BgCardBrush}" CornerRadius="10" Padding="16">
                <StackPanel>
                    <TextBlock Text="CONFIDENCE" FontSize="9" FontWeight="SemiBold"                                Foreground="{StaticResource TextSecondaryBrush}"/>
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="ConfidenceDisplay" Text="0%" FontSize="22" FontWeight="SemiBold">
                            <TextBlock.Foreground>
                                <SolidColorBrush Color="{StaticResource ConfColor}"/>
                            </TextBlock.Foreground>
                        </TextBlock>
                        <!-- Confidence Bar -->
                        <Border Grid.Column="1" Height="6" CornerRadius="3" Background="#2A2A2A"
                                VerticalAlignment="Center" Margin="12,0,0,0">
                            <Border x:Name="ConfidenceBar" Background="#FFB800" CornerRadius="3"
                                    HorizontalAlignment="Left" Width="0"/>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Parameters Section -->
        <Border Grid.Row="3" Background="{StaticResource BgCardBrush}" CornerRadius="12" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="PARAMETERS" FontSize="10" FontWeight="SemiBold"                            Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="ParametersPanel">
                        <!-- Parameters will be added dynamically -->
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
